NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Web Push (값은 Railway Variables / Supabase Secrets에서 관리, 절대 커밋 X)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# 계정 보관함 암호화 키 (서버 전용 — NEXT_PUBLIC 접두어 절대 금지)
# 32바이트 base64. 생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ⚠️ 이 키를 분실/변경하면 저장된 계정 비밀번호를 복호화할 수 없습니다. Railway Variables에 안전히 보관.
ACCOUNT_VAULT_KEY=
